# ── Gemini AI ──────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Google Cloud Storage (optional — outputs stored locally if not set) ────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=studioagent-videos
# Path to a service account JSON key with Storage Object Admin role
GOOGLE_APPLICATION_CREDENTIALS=

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
DEBUG=false

# ── Processing ─────────────────────────────────────────────────────────────
TEMP_DIR=./tmp
MAX_UPLOAD_SIZE_MB=500

# ── FFmpeg ─────────────────────────────────────────────────────────────────
# Leave as "ffmpeg" when running in Docker (system FFmpeg is on PATH).
# On Windows dev machine this is auto-detected from the imageio_ffmpeg bundle.
FFMPEG_PATH=ffmpeg
